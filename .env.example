# Supabase (database + storage)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Public domain (subdomains: [slug].yourdomain → /p/[slug])
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Twilio WhatsApp (templates must be pre-approved in Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Twilio Content Template SIDs (required for production WhatsApp outside sandbox / 24h session)
# Create in Twilio Console → Content Template Builder, submit each for WhatsApp approval (HX… SIDs).
TWILIO_CONTENT_SID_NEW_LEAD_SALESPERSON=
TWILIO_CONTENT_SID_NEW_LEAD_MANAGER=
TWILIO_CONTENT_SID_DEAL_WON=
TWILIO_CONTENT_SID_FOLLOW_UP_REMINDER=
TWILIO_CONTENT_SID_UNCONTACTED_LEAD_ALERT=

# When template SIDs are unset, outbound WhatsApp may use freeform body (Twilio sandbox / dev only).

# Default country (ISO 3166-1 alpha-2) for phone numbers submitted without a country code
DEFAULT_COUNTRY_CODE=ZW

# Resend — both required for outbound email (From must use a domain verified in Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Facebook Lead Ads — OAuth + webhook (add redirect URL in Meta app: Valid OAuth Redirect URIs)
# OAuth scopes in code include ads_read and pages_manage_ads (Campaigns / Marketing API + Page-linked ads).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/facebook/oauth/callback
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your-verify-token
FACEBOOK_API_VERSION=v19.0

# Cron / Vercel — long random string (e.g. openssl rand -hex 32). Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
# Hobby (free): use one daily job in vercel.json → /api/cron/daily. For more frequent uncontacted checks, ping
# /api/cron/check-leads from an external free scheduler (same Bearer header).
CRON_SECRET=
